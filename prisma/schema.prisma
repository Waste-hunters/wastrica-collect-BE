generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  COMPANY_ADMIN
  MANAGER
  COLLECTOR
  HOUSEHOLD
  SYSTEM
}

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

enum SubscriptionTier {
  STARTER
  GROWTH
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum LateFeeType {
  FLAT
  PERCENTAGE
}

enum HouseholdStatus {
  ACTIVE
  SUSPENDED
  RELOCATED
  DECEASED
}

enum BillingPeriodStatus {
  OPEN
  ACTIVE
  CLOSED
}

enum ChargeStatus {
  PENDING
  PAID
  PARTIALLY_PAID
  OVERDUE
  WAIVED
}

enum PaymentMethod {
  MOMO_MTN
  MOMO_AIRTEL
  EKASH
  CASH
  OTHER
}

enum PaymentSource {
  SYSTEM
  COLLECTOR
  HOUSEHOLD_CLAIM
}

enum PaymentProofStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MomoCollectionStatus {
  PENDING
  SUCCESSFUL
  FAILED
}

model Company {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String
  ruraLicenseNumber  String?            @unique @map("rura_license_number")
  contactPhone       String             @map("contact_phone")
  contactEmail       String?            @map("contact_email")
  subscriptionTier   SubscriptionTier   @default(STARTER) @map("subscription_tier")
  subscriptionStatus SubscriptionStatus @default(TRIAL) @map("subscription_status")
  lateFeeGraceDays   Int                @default(10) @map("late_fee_grace_days")
  lateFeeType        LateFeeType        @default(FLAT) @map("late_fee_type")
  lateFeeAmountRwf   Int                @default(0) @map("late_fee_amount_rwf")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  users              User[]
  households         Household[]
  routes             Route[]
  billingPeriods     BillingPeriod[]

  @@map("companies")
}

model User {
  id          String     @id @default(uuid()) @db.Uuid
  companyId   String?    @map("company_id") @db.Uuid
  company     Company?   @relation(fields: [companyId], references: [id])
  fullName    String     @map("full_name")
  phoneNumber String     @unique @map("phone_number")
  email       String?
  role        UserRole
  status      UserStatus @default(INVITED)
  invitedById String?    @map("invited_by_id") @db.Uuid
  invitedBy   User?      @relation("UserInvites", fields: [invitedById], references: [id])
  invites     User[]     @relation("UserInvites")
  lastLoginAt DateTime?  @map("last_login_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  passwordHash   String?    @map("password_hash")
  householdId    String?    @unique @map("household_id") @db.Uuid
  household      Household? @relation("HouseholdUser", fields: [householdId], references: [id])
  otpChallenges  OtpChallenge[]
  collectorRoutes Route[] @relation("CollectorRoutes")
  assignedHouseholds Household[] @relation("CollectorHouseholds")
  collectorPayments Payment[] @relation("CollectorPayments")

  @@index([companyId, role])
  @@map("users")
}

model Route {
  id            String      @id @default(uuid()) @db.Uuid
  companyId     String      @map("company_id") @db.Uuid
  company       Company     @relation(fields: [companyId], references: [id])
  collectorId   String?     @map("collector_id") @db.Uuid
  collector     User?       @relation("CollectorRoutes", fields: [collectorId], references: [id])
  name          String
  sector        String
  cell          String?
  village       String?
  description   String?
  collectionDay Int?        @map("collection_day")
  isActive      Boolean     @default(true) @map("is_active")
  households    Household[]
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@index([companyId, collectorId])
  @@map("routes")
}

model Household {
  id             String              @id @default(uuid()) @db.Uuid
  companyId      String              @map("company_id") @db.Uuid
  company        Company             @relation(fields: [companyId], references: [id])
  collectorId    String?             @map("collector_id") @db.Uuid
  collector      User?               @relation("CollectorHouseholds", fields: [collectorId], references: [id])
  routeId        String?             @map("route_id") @db.Uuid
  route          Route?              @relation(fields: [routeId], references: [id])
  householdCode  String              @map("household_code")
  residentName   String              @map("resident_name")
  phoneNumber    String              @map("phone_number")
  momoNumber     String?             @map("momo_number")
  sector         String
  cell           String
  village        String?
  address        String?
  latitude       Decimal?            @db.Decimal(9, 6)
  longitude      Decimal?            @db.Decimal(9, 6)
  monthlyFeeRwf  Int                 @map("monthly_fee_rwf")
  collectionDay  Int                 @map("collection_day")
  status         HouseholdStatus     @default(ACTIVE)
  verifiedAt     DateTime?           @map("verified_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  email          String?             @unique
  emailVerifiedAt DateTime?           @map("email_verified_at")
  feeHistory     HouseholdFeeHistory[]
  charges        Charge[]
  payments       Payment[]
  paymentProofs  PaymentProof[]
  momoCollections MomoCollection[]
  householdUser  User?               @relation("HouseholdUser")

  @@unique([companyId, householdCode])
  @@index([companyId, status])
  @@index([collectorId])
  @@index([routeId])
  @@map("households")
}

model HouseholdFeeHistory {
  id             String    @id @default(uuid()) @db.Uuid
  householdId    String    @map("household_id") @db.Uuid
  household      Household @relation(fields: [householdId], references: [id])
  previousFeeRwf Int?      @map("previous_fee_rwf")
  newFeeRwf      Int       @map("new_fee_rwf")
  effectiveFrom  DateTime  @map("effective_from")
  reason         String?
  changedById    String?   @map("changed_by_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([householdId, effectiveFrom])
  @@map("household_fee_history")
}

model OtpChallenge {
  id          String    @id @default(uuid()) @db.Uuid
  phoneNumber String    @map("phone_number")
  codeHash    String    @map("code_hash")
  consumedAt  DateTime? @map("consumed_at")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  userId      String?   @map("user_id") @db.Uuid
  user        User?     @relation(fields: [userId], references: [id])

  @@index([phoneNumber, expiresAt])
  @@map("otp_challenges")
}

model EmailOtpChallenge {
  id         String    @id @default(uuid()) @db.Uuid
  email      String
  codeHash   String    @map("code_hash")
  consumedAt DateTime? @map("consumed_at")
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([email, expiresAt])
  @@map("email_otp_challenges")
}

model BillingPeriod {
  id                 String              @id @default(uuid()) @db.Uuid
  companyId          String              @map("company_id") @db.Uuid
  company            Company             @relation(fields: [companyId], references: [id])
  year               Int
  month              Int
  periodStart        DateTime            @map("period_start") @db.Date
  periodEnd          DateTime            @map("period_end") @db.Date
  status             BillingPeriodStatus @default(OPEN)
  chargesGeneratedAt DateTime?           @map("charges_generated_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  charges Charge[]

  @@unique([companyId, year, month])
  @@index([companyId, status])
  @@map("billing_periods")
}

model Charge {
  id              String       @id @default(uuid()) @db.Uuid
  billingPeriodId String       @map("billing_period_id") @db.Uuid
  billingPeriod   BillingPeriod @relation(fields: [billingPeriodId], references: [id])
  householdId     String       @map("household_id") @db.Uuid
  household       Household    @relation(fields: [householdId], references: [id])
  companyId       String       @map("company_id") @db.Uuid
  baseFeeRwf      Int          @map("base_fee_rwf")
  lateFeeRwf      Int          @default(0) @map("late_fee_rwf")
  totalAmountRwf  Int          @map("total_amount_rwf")
  amountPaidRwf   Int          @default(0) @map("amount_paid_rwf")
  status          ChargeStatus @default(PENDING)
  dueDate         DateTime     @map("due_date") @db.Date
  paidAt          DateTime?    @map("paid_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  payments        Payment[]
  paymentProofs   PaymentProof[]
  momoCollections MomoCollection[]

  @@unique([billingPeriodId, householdId])
  @@index([householdId, status])
  @@index([companyId, status])
  @@map("charges")
}

model Payment {
  id                String        @id @default(uuid()) @db.Uuid
  companyId         String        @map("company_id") @db.Uuid
  householdId       String        @map("household_id") @db.Uuid
  household         Household     @relation(fields: [householdId], references: [id])
  chargeId          String?       @map("charge_id") @db.Uuid
  charge            Charge?       @relation(fields: [chargeId], references: [id])
  billingPeriodId   String?       @map("billing_period_id") @db.Uuid
  collectorId       String?       @map("collector_id") @db.Uuid
  collector         User?         @relation("CollectorPayments", fields: [collectorId], references: [id])
  amountRwf         Int           @map("amount_rwf")
  paymentMethod     PaymentMethod @map("payment_method")
  momoTransactionId String?       @unique @map("momo_transaction_id")
  source            PaymentSource @default(COLLECTOR)
  paidAt            DateTime      @map("paid_at")
  note              String?
  recordedById      String?       @map("recorded_by_id") @db.Uuid
  isReversed        Boolean       @default(false) @map("is_reversed")
  reversalReason    String?       @map("reversal_reason")
  reversedById      String?       @map("reversed_by_id") @db.Uuid
  reversedAt        DateTime?     @map("reversed_at")
  proof             PaymentProof?
  momoCollection    MomoCollection?
  createdAt         DateTime      @default(now()) @map("created_at")

  @@index([householdId])
  @@index([companyId])
  @@index([chargeId])
  @@index([collectorId])
  @@map("payments")
}

model MomoCollection {
  id                    String               @id @default(uuid()) @db.Uuid
  referenceId           String               @unique @map("reference_id") @db.Uuid
  companyId             String               @map("company_id") @db.Uuid
  householdId           String               @map("household_id") @db.Uuid
  household             Household            @relation(fields: [householdId], references: [id])
  chargeId              String               @map("charge_id") @db.Uuid
  charge                Charge               @relation(fields: [chargeId], references: [id])
  billingPeriodId       String?              @map("billing_period_id") @db.Uuid
  payerPhone            String               @map("payer_phone")
  amountRwf             Int                  @map("amount_rwf")
  currency              String               @default("EUR")
  externalId            String               @map("external_id")
  status                MomoCollectionStatus @default(PENDING)
  financialTransactionId String?             @map("financial_transaction_id")
  failureReason         String?              @map("failure_reason")
  initiatedById         String?              @map("initiated_by_id") @db.Uuid
  paymentId             String?              @unique @map("payment_id") @db.Uuid
  payment               Payment?             @relation(fields: [paymentId], references: [id])
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  @@index([companyId, status])
  @@index([householdId])
  @@map("momo_collections")
}

model PaymentProof {
  id                String             @id @default(uuid()) @db.Uuid
  companyId         String             @map("company_id") @db.Uuid
  householdId       String             @map("household_id") @db.Uuid
  household         Household          @relation(fields: [householdId], references: [id])
  billingPeriodId   String?            @map("billing_period_id") @db.Uuid
  chargeId          String?            @map("charge_id") @db.Uuid
  charge            Charge?            @relation(fields: [chargeId], references: [id])
  submittedById     String?            @map("submitted_by_id") @db.Uuid
  claimedAmountRwf  Int                @map("claimed_amount_rwf")
  paymentMethod     PaymentMethod      @map("payment_method")
  momoTransactionId String?            @map("momo_transaction_id")
  proofImageUrl     String?            @map("proof_image_url")
  note              String?
  status            PaymentProofStatus @default(PENDING)
  reviewedById      String?            @map("reviewed_by_id") @db.Uuid
  reviewedAt        DateTime?          @map("reviewed_at")
  rejectionReason   String?            @map("rejection_reason")
  paymentId         String?            @unique @map("payment_id") @db.Uuid
  payment           Payment?           @relation(fields: [paymentId], references: [id])
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  @@index([companyId, status])
  @@index([householdId])
  @@map("payment_proofs")
}

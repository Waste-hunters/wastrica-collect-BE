generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  COMPANY_ADMIN
  MANAGER
  COLLECTOR
  HOUSEHOLD
  SYSTEM
}

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

enum SubscriptionTier {
  STARTER
  GROWTH
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum LateFeeType {
  FLAT
  PERCENTAGE
}

model Company {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String
  ruraLicenseNumber  String?            @unique @map("rura_license_number")
  contactPhone       String             @map("contact_phone")
  contactEmail       String?            @map("contact_email")
  subscriptionTier   SubscriptionTier   @default(STARTER) @map("subscription_tier")
  subscriptionStatus SubscriptionStatus @default(TRIAL) @map("subscription_status")
  lateFeeGraceDays   Int                @default(10) @map("late_fee_grace_days")
  lateFeeType        LateFeeType        @default(FLAT) @map("late_fee_type")
  lateFeeAmountRwf   Int                @default(0) @map("late_fee_amount_rwf")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  users              User[]

  @@map("companies")
}

model User {
  id          String     @id @default(uuid()) @db.Uuid
  companyId   String?    @map("company_id") @db.Uuid
  company     Company?   @relation(fields: [companyId], references: [id])
  fullName    String     @map("full_name")
  phoneNumber String     @unique @map("phone_number")
  email       String?
  role        UserRole
  status      UserStatus @default(INVITED)
  invitedById String?    @map("invited_by_id") @db.Uuid
  invitedBy   User?      @relation("UserInvites", fields: [invitedById], references: [id])
  invites     User[]     @relation("UserInvites")
  lastLoginAt DateTime?  @map("last_login_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  otpChallenges OtpChallenge[]

  @@index([companyId, role])
  @@map("users")
}

model OtpChallenge {
  id          String    @id @default(uuid()) @db.Uuid
  phoneNumber String    @map("phone_number")
  codeHash    String    @map("code_hash")
  consumedAt  DateTime? @map("consumed_at")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  userId      String?   @map("user_id") @db.Uuid
  user        User?     @relation(fields: [userId], references: [id])

  @@index([phoneNumber, expiresAt])
  @@map("otp_challenges")
}

################################################################################
# Wastrica Collect — environment configuration blueprint
# Copy this file to `.env` and fill in real values. Never commit `.env`.
################################################################################

# ─── Core ─────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wastrica_collect?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
NODE_ENV="development"
PORT=3000

# ─── Email OTP (currently used for staff + household verification) ─────────────
# Any SMTP provider works (Gmail App Password, Mailtrap, Brevo, etc.).
# If these are left blank, OTP codes are printed to the server logs (dev mode).
EMAIL_HOST=""
EMAIL_PORT=587
EMAIL_USER=""
EMAIL_PASS=""
EMAIL_FROM="Wastrica Collect <no-reply@wastrica.io>"

# ─── Africa's Talking SMS (optional — SMS sending is currently disabled) ───────
# Use username "sandbox" with sandbox credentials. For live SMS use your app name.
AFRICASTALKING_USERNAME="sandbox"
AFRICASTALKING_API_KEY="replace-with-africastalking-api-key"
AFRICASTALKING_SENDER_ID=""

################################################################################
# PAYMENTS MODULE
################################################################################

# ─── Webhook security ──────────────────────────────────────────────────────────
# Shared secret expected in the `x-webhook-secret` header on provider callbacks
# (POST /payments/momo/webhook and /payments/airtel/webhook).
# If left blank, webhook signature verification is DISABLED (dev only) so you can
# test with simulated payloads. Set a strong value before going live.
MOMO_WEBHOOK_SECRET=""

# ─── MTN MoMo Collections API (FREE sandbox) ───────────────────────────────────
# How to get these (all free, no card required):
#   1. Sign up at https://momodeveloper.mtn.com
#   2. Open the "Collections" product and click Subscribe -> copy the Primary Key
#      into MOMO_MTN_SUBSCRIPTION_KEY below.
#   3. Provision a sandbox API User + API Key (portal flow, or the
#      /v1_0/apiuser provisioning calls) -> fill MOMO_MTN_API_USER / API_KEY.
#   4. Use environment "sandbox" while developing; "mtnrwanda" (or as issued) for live.
MOMO_MTN_SUBSCRIPTION_KEY=""
MOMO_MTN_API_USER=""
MOMO_MTN_API_KEY=""
MOMO_MTN_ENVIRONMENT="sandbox"
MOMO_MTN_CALLBACK_HOST=""
# Base URL of the MoMo API. Sandbox default shown; change for production.
MOMO_MTN_BASE_URL="https://sandbox.momodeveloper.mtn.com"
# Sandbox only accepts EUR. Leave blank to auto-pick (EUR in sandbox, RWF in prod).
MOMO_MTN_CURRENCY=""

# ─── Airtel Money Collections API (FREE staging) ───────────────────────────────
# How to get these (free staging environment):
#   1. Sign up at https://developers.airtel.africa
#   2. Create an App -> copy the Client ID and Client Secret below.
#   3. Use the "staging" base URL while developing; "production" once approved.
AIRTEL_CLIENT_ID=""
AIRTEL_CLIENT_SECRET=""
AIRTEL_ENVIRONMENT="staging"
AIRTEL_COUNTRY="RW"
AIRTEL_CURRENCY="RWF"

# ─── eKash / RNDPS 2.0 (NOT free / not publicly available yet) ─────────────────
# Bank/RSwitch-gated; no public dev sandbox. Leave blank for now — the payment
# provider design allows adding this later without core changes.
EKASH_BASE_URL=""
EKASH_CLIENT_ID=""
EKASH_CLIENT_SECRET=""

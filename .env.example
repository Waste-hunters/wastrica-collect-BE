DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wastrica_collect?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
NODE_ENV="development"

# Africa's Talking SMS
# Use username "sandbox" only with sandbox credentials. For live SMS, use your live app username.
AFRICASTALKING_USERNAME="sandbox"
AFRICASTALKING_API_KEY="replace-with-africastalking-api-key"
AFRICASTALKING_SENDER_ID=""
